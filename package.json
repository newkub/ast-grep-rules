{
  "name": "@wrikka/ast-grep-cli",
  "version": "0.1.0",
  "description": "CLI tool for managing and running ast-grep rules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ast-grep-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "rules"
  ],
  "scripts": {
    "build": "bunup",
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "verify": "bun run typecheck && bun run lint && bun run test",
    "prepublishOnly": "bun run build",
    "release": "bun run verify && bun run build && npm publish"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.1",
    "cac": "^7.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "biome": "^0.3.3",
    "bunup": "^0.16.31",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ast-grep",
    "cli",
    "linting",
    "code-analysis",
    "typescript"
  ],
  "author": "Wrikka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wrikka/booking-platform",
    "directory": "ast-grep-rules"
  }
}
